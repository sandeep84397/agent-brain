compiler_sample @module {
  src: 1-1
  purpose: import deterministic JSON serialization dependency
  deps: json
}

compiler_sample.JsonEnvelope @model {
  src: 4-11
  purpose: prefix deterministic JSON renderings
  deps: json.dumps(sort_keys=True)
  fn:__init__(self, prefix: str) -> None
  fn:render(self, payload: dict[str, object]) -> str
  @state: self.prefix: str = prefix
  @errors: ValueError("payload must not be empty") when payload is empty
  @constraint: payload must be non-empty
}

compiler_sample.JsonEnvelope.__init__ @fn {
  src: 5-6
  purpose: initialize rendering prefix
  fn:__init__(self, prefix: str) -> None
  @state: self.prefix: str = prefix
}

compiler_sample.JsonEnvelope.render @fn {
  src: 8-11
  purpose: render prefixed deterministic JSON
  deps: json.dumps(sort_keys=True)
  fn:render(self, payload: dict[str, object]) -> str
  @errors: ValueError("payload must not be empty") when payload is empty
  @constraint: payload must be non-empty
}
